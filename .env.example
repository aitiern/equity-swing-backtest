# Copy this file to ".env" and fill in your Alpaca PAPER keys.
# The real ".env" is git-ignored and must NEVER be committed.
# Get paper keys at https://app.alpaca.markets/ -> Paper Trading -> API Keys.

ALPACA_API_KEY=your_paper_key_id_here
ALPACA_SECRET_KEY=your_paper_secret_here

# Hard safety switch. Leave as "true". The code refuses to run if this is false.
ALPACA_PAPER=true

# Universe + strategy the auto-trader uses (must match a sector in src/universe.py
# and a strategy in the registry).
TRADE_SECTOR=tech
TRADE_STRATEGY=donchian
